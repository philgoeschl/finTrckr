# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Strong password for the PostgreSQL database
POSTGRES_PASSWORD=change_me_to_a_strong_password

# DATABASE_URL is assembled automatically in docker-compose.yml from POSTGRES_PASSWORD.
# Only set this manually when running Next.js outside of Docker (e.g. local dev without Compose):
# DATABASE_URL=postgresql://fintrckr:<POSTGRES_PASSWORD>@localhost:5432/fintrckr

# --- Future: user auth (uncomment when adding Better Auth) ---
# AUTH_SECRET=generate_with_openssl_rand_base64_32
# AUTH_URL=http://localhost:3000
